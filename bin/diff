#!/bin/sh

set -e

HOST=${1:-pi}

nom build .#nixosConfigurations.$HOST.config.system.build.toplevel

if_remote() {
    if [ "$(uname -n)" != "$HOST" ]; then
        "$@"
    fi
}

local_or_remote() {
    prefix=""
    if_remote prefix="ssh $HOST "
    echo $prefix
    $prefix "$@"
}


OUT_PATH=result
CURRENT_SYSTEM=$(local_or_remote readlink /run/current-system)

#echo "OUT_PATH: $OUT_PATH"
#echo "CURRENT_SYSTEM: $CURRENT_SYSTEM"

# fetch the current system closure, so I can diff it
if_remote nix copy --no-check-sigs --from ssh-ng://$HOST $CURRENT_SYSTEM

# package level diff
nvd diff $CURRENT_SYSTEM $OUT_PATH

# file level diff
#nix run nixpkgs#nix-diff -- \
#      $CURRENT_SYSTEM \
#      $OUT_PATH \
#      --color always
# nix-diff: unknown-deriver: withBinaryFile: does not exist (No such file or directory)
